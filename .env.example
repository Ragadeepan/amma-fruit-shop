# -----------------------------
# Backend
# -----------------------------
NODE_ENV=development
PORT=5000
PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
CLIENT_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=12h
ORDER_ACCESS_SECRET=replace-with-a-separate-order-token-secret
ORDER_ACCESS_EXPIRES_IN=48h
ADMIN_EMAIL=admin@ammafruitshop.com
ADMIN_PASSWORD=Admin@12345
DUPLICATE_WINDOW_MINUTES=10
UPI_ID=ammafruitshop@upi
UPI_PAYEE_NAME=Amma Fruit Shop
WHATSAPP_ENABLED=false
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_RECIPIENT_OVERRIDE=

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Firebase Firestore (service account)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=
# Alternative to inline keys:
# FIREBASE_SERVICE_ACCOUNT_PATH=backend/credentials/firebase-service-account.json
# Local development (optional, no real Firebase keys needed):
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# -----------------------------
# Frontend
# -----------------------------
VITE_API_BASE_URL=http://localhost:5000/api/v1
